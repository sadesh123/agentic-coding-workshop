---
/**
 * Layout.astro
 * 
 * Provides the HTML shell for all pages: <html>, <head> with meta tags and font loading,
 * and <body> with a <main> slot for page content.
 * 
 * Props:
 *   - title (string): Page title rendered in <title> and <meta property="og:title">
 */

// 🥚 KIRO TIP: Use steering files to maintain persistent context across all your Kiro interactions—set rules once and Kiro remembers them!

import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Professional resume website built with Astro" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Professional resume website built with Astro" />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
