---
/**
 * Kiro Ghost Icon Component
 * Displays the official Kiro friendly-ghost mascot as an inline SVG.
 * Used as a visual marker for Easter egg UI elements throughout the codebase.
 * Props:
 *   - size?: number (default: 24) - Icon size in pixels
 *   - aria-label?: string - Accessible label for the icon
 */

interface Props {
  size?: number;
  'aria-label'?: string;
}

const { size = 24, 'aria-label': ariaLabel = 'Kiro ghost' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  aria-label={ariaLabel}
>
  <!-- Purple background -->
  <rect width="100" height="100" rx="20" fill="#a855f7" />
  
  <!-- Ghost body (white) -->
  <g fill="white">
    <!-- Main body -->
    <path d="M 25 30 Q 25 20, 35 20 L 65 20 Q 75 20, 75 30 L 75 65 Q 75 75, 65 75 L 35 75 Q 25 75, 25 65 Z" />
    
    <!-- Left bottom wave -->
    <path d="M 25 65 Q 20 75, 30 80 Q 35 75, 35 75" />
    
    <!-- Middle bottom wave -->
    <path d="M 40 75 Q 40 80, 50 82 Q 60 80, 60 75" />
    
    <!-- Right bottom wave -->
    <path d="M 65 75 Q 65 75, 70 80 Q 80 75, 75 65" />
  </g>
  
  <!-- Left eye (black) -->
  <ellipse cx="38" cy="42" rx="5" ry="8" fill="black" />
  
  <!-- Right eye (black) -->
  <ellipse cx="62" cy="42" rx="5" ry="8" fill="black" />
</svg>
