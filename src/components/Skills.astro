---
/**
 * Skills Component
 * Displays technical skills grouped by category.
 * Props:
 *   - data: SkillsData - Contains skill categories and individual skills
 */

import type { SkillsData } from '../data/resume';

interface Props {
  data: SkillsData;
}

const { data } = Astro.props;
---

<section id="skills">
  <h2>Skills</h2>
  {data.categories.length === 0 ? (
    <p class="empty-state">No entries yet.</p>
  ) : (
    <div>
      {data.categories.map((category, catIndex) => (
        <div style={`margin-bottom: 2rem; animation: slideInUp 0.5s ease-out; animation-delay: ${catIndex * 0.1}s; animation-fill-mode: both;`}>
          <h3>{category.category}</h3>
          <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
            {category.skills.map((skill, skillIndex) => (
              <span
                style={`
                  display: inline-block;
                  background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
                  color: white;
                  padding: 0.6rem 1.2rem;
                  border-radius: 20px;
                  font-size: var(--font-size-small);
                  font-weight: 500;
                  transition: all 0.3s ease;
                  animation: scaleIn 0.4s ease-out;
                  animation-delay: ${(catIndex * 0.1) + (skillIndex * 0.05)}s;
                  animation-fill-mode: both;
                  cursor: pointer;
                  box-shadow: 0 2px 8px rgba(124, 58, 237, 0.2);
                `}
                class="skill-tag"
              >
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  )}
</section>

<style>
  .skill-tag {
    position: relative;
    overflow: hidden;
  }

  .skill-tag::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s ease;
  }

  .skill-tag:hover::before {
    left: 100%;
  }

  .skill-tag:hover {
    transform: translateY(-4px) scale(1.1);
    box-shadow: 0 8px 16px rgba(124, 58, 237, 0.4);
  }
</style>
